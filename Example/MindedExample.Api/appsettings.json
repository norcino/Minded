{
    "Logging": {
        "IncludeScopes": true,
        "LogLevel": {
            "Default": "Information",
            "System": "Warning",
            "Microsoft": "Warning"
        }
    },
    "DatabaseType": "SQLServer",
    "ConnectionStrings": {
        "MindedExample": "server=.;database=MindedExample;Integrated Security=SSPI"
    },
    "Minded": {
        "LoggingOptions": {
            "Enabled": true,
            "LogMessageTemplateData": true,
            "LogOutcomeEntries": false,
            "MinimumOutcomeSeverityLevel": "Info"
        },
        "ExceptionOptions": {
            "Serialize": true
        },
        "RetryOptions": {
            "ApplyToAllQueries": false,
            "DefaultRetryCount": 3,
            "DefaultDelay1": 100,
            "DefaultDelay2": 200,
            "DefaultDelay3": 400,
            "DefaultDelay4": 0,
            "DefaultDelay5": 0
        },
        "DataProtectionOptions": {
            "ShowSensitiveData": false
        },
        "TransactionOptions": {
            "DefaultTransactionScopeOption": "Required",
            "DefaultIsolationLevel": "ReadCommitted",
            "DefaultTimeoutSeconds": 60,
            "RollbackOnUnsuccessfulResponse": true,
            "EnableLogging": true
        }
    }
}
