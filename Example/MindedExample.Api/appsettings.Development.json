{
    "LogFile": "Logs/api-dev-{Date}.txt",
    "Logging": {
        "IncludeScopes": true,
        "LogLevel": {
            "Default": "Debug",
            "System": "Debug",
            "Microsoft": "Debug"
        }
    },
    // PostgreSQL (default) requires the database container:
    //   docker compose -f docker-compose.tests.yml up -d
    // Set to "SQLiteInMemory" for a zero-infrastructure in-memory database,
    // or "SQLServer"/"LocalDb" to use the MindedExample connection string.
    "DatabaseType": "PostgreSQL",
    "Jwt": {
        "Issuer": "MindedExample",
        "Audience": "MindedExample.Frontend",
        "SigningKey": "ThisIsADevelopmentOnlySigningKeyPleaseChange"
    },
    "ConnectionStrings": {
        "MindedExample": "server=.;database=HouseKeeping_Dev;Integrated Security=SSPI;Trust Server Certificate=true",
        "MindedExamplePostgreSQL": "Host=localhost;Port=5433;Database=mindedexample;Username=minded;Password=minded"
    }
}
