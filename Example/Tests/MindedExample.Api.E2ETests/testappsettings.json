    // ************************************
    // Integration Testing for Live execution using SQLite in Memory
    // ************************************
     "TestingProfile": "E2ELive",
     "DatabaseType": "SQLiteInMemory",
     "ConnectionStrings": {
       "MindedExample": "",
       // Used by the PostgreSQL E2E profile; each run targets a unique database derived
       // from this name (minded_apitests_<runid>), created and dropped automatically.
       "MindedExamplePostgreSQL": "Host=localhost;Port=5433;Database=minded_apitests;Username=minded;Password=minded"
     }

    // ************************************
