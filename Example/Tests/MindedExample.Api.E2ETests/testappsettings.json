{
    "LogFile": "Logs/api-test-{Date}.txt",
    "Logging": {
        "IncludeScopes": false,
        "LogLevel": {
            "Default": "Debug",
            "System": "Debug",
            "Microsoft": "Debug"
        }
    },

    // ************************************
    // UnitTesting configuration example
