<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
		<clear />
		<add key="Local Minded" value="..\bin\Release" />
		<add key="NuGet.org" value="https://api.nuget.org/v3/index.json" />
    </packageSources>
    <packageSourceMapping>
        <packageSource key="NuGet.org">
            <package pattern="*" />
        </packageSource>
        <packageSource key="Local Minded">
            <package pattern="Minded.*" />
        </packageSource>
    </packageSourceMapping>
</configuration>