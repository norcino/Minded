    <SignAssembly>True</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\Extensions\Minded.Extensions.Context\key.snk</AssemblyOriginatorKeyFile>
  </PropertyGroup>
  <ItemGroup>
